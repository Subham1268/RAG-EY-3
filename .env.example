# ─── OpenAI (the ONLY credential you personally need) ────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

# ─── Pinecone (shared vector store — embed ONCE) ─────────
# Once you ingest, the vectors live here. Anyone pointed at the
# same index queries it directly — they never re-embed your docs.
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=ey-me-openai
PINECONE_NAMESPACE_TEXT=text-chunks
PINECONE_NAMESPACE_IMAGE=image-chunks

# ─── PostgreSQL (shared metadata + full chunk text) ──────
DATABASE_URL=postgresql+asyncpg://ey_rag_user:localdev_password@localhost:5432/ey_rag

# ─── App ─────────────────────────────────────────────────
# development = API is open (no auth). The system needs no key
# beyond OPENAI_API_KEY. Reranking is done with OpenAI (no Cohere).
APP_ENV=development
COLPALI_ENABLED=true
MAX_RETRIEVAL_K=20
RERANK_TOP_N=8
CHUNK_SIZE=800
CHUNK_OVERLAP=150
MAX_REFLECTION_LOOPS=2
