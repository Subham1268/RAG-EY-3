# ─── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# ─── Pinecone ────────────────────────────────────────────
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=ey-me-knowledge
PINECONE_NAMESPACE_TEXT=text-chunks
PINECONE_NAMESPACE_IMAGE=image-chunks

# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ey_rag
POSTGRES_USER=ey_rag_user
POSTGRES_PASSWORD=...
DATABASE_URL=postgresql+asyncpg://ey_rag_user:...@localhost:5432/ey_rag



# ─── Cohere ──────────────────────────────────────────────
COHERE_API_KEY=...
COHERE_RERANK_MODEL=rerank-english-v3.0

# ─── Azure AD ────────────────────────────────────────────
AZURE_TENANT_ID=...
AZURE_CLIENT_ID=...
AZURE_CLIENT_SECRET=...
AZURE_AD_AUDIENCE=api://ey-rag-agent

# ─── Teams Bot ───────────────────────────────────────────
MICROSOFT_APP_ID=...
MICROSOFT_APP_PASSWORD=...

# ─── LangSmith ───────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=ey-me-agentic-rag

# ─── App Settings ────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO
MAX_RETRIEVAL_K=20           # Initial retrieval count
RERANK_TOP_N=5               # After reranking
CHUNK_SIZE=800
CHUNK_OVERLAP=150
MAX_REFLECTION_LOOPS=2       # Max self-RAG retry loops
CACHE_TTL_SECONDS=3600
